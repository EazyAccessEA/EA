# Cloudflare Turnstile
# Client-side key (exposed in browser) — set in Cloudflare Pages env vars too
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# Server-side key — set as a Cloudflare Pages environment variable (Settings > Environment variables)
# Do NOT add TURNSTILE_SECRET_KEY here — it is only used in the Pages Function
# and should be configured in the Cloudflare dashboard.

# Dummy keys for local development:
#   Site key:   1x00000000000000000000AA (always passes)
#   Secret key: 1x0000000000000000000000000000000AA (always passes)
# See: https://developers.cloudflare.com/turnstile/troubleshooting/testing/
